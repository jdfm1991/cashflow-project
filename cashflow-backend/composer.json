{
    "name": "cashflow/backend",
    "description": "Backend API para sistema de flujo de caja",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.5",
        "firebase/php-jwt": "^7.0",
        "phpoffice/phpspreadsheet": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "test": "phpunit tests/",
        "lint": "phpcs --standard=PSR12 app/"
    }
}
