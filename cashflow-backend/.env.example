# Configuración de la aplicación
APP_NAME="CashFlow System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Configuración de base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cashflow_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Configuración CORS
ALLOWED_ORIGIN=http://localhost:3000

# Configuración JWT
JWT_SECRET=tu_secreto_super_seguro_cambia_esto_en_produccion
JWT_EXPIRATION=3600

# Configuración de logs
LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log